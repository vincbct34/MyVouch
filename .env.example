# Vouch — environment

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=change_me_to_a_long_random_string
BASE_URL=http://localhost:3000

# Set to "production" when deploying (enables secure cookies).
NODE_ENV=development

# Set to true only behind a trusted proxy that controls x-forwarded-for.
TRUST_PROXY=false

# Email — required in production for reviewer email confirmation.
# Sender address shown on confirmation emails.
EMAIL_FROM=Vouch <no-reply@vouch.app>
# Option A: Resend (https://resend.com)
RESEND_API_KEY=
# Option B: SMTP (used only if RESEND_API_KEY is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# In development, if no provider is configured, confirmation links are logged
# to the server console instead of being emailed.
