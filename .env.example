# Vouch — environment

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=change_me_to_a_long_random_string
BASE_URL=http://localhost:3000

# Set to "production" when deploying (enables secure cookies).
NODE_ENV=development

# Set to true only behind a trusted proxy that controls x-forwarded-for.
TRUST_PROXY=false

# Email (Resend) — required in production for reviewer email confirmation.
# Sender address shown on confirmation emails. Must be on a domain you've
# verified in Resend (the default below will be rejected in production).
EMAIL_FROM=Vouch <no-reply@vouch.app>
# https://resend.com — API key (uses fetch, no extra dependency).
RESEND_API_KEY=
# In development, if RESEND_API_KEY is unset, confirmation links are logged
# to the server console instead of being emailed.
